# ══════════════════════════════════════════════════════════════
#  QRNG Analysis Toolkit — API Keys
# ══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your actual keys.
#  NEVER commit the .env file to version control.
# ══════════════════════════════════════════════════════════════

# Outshift QRNG API (SPDC photon source)
# Sign up: https://random.outshift.com/
QRNG_OUTSHIFT_API_KEY=your_outshift_api_key_here
QRNG_OUTSHIFT_API_URL=https://api.qrng.outshift.com/api/v1/random_numbers

# ANU QRNG (vacuum fluctuation)
# Sign up: https://quantumnumbers.anu.edu.au/
ANU_QRNG_API_KEY=your_anu_api_key_here
ANU_QRNG_API_URL=https://api.quantumnumbers.anu.edu.au/

# IBM Quantum (superconducting qubits)
# Sign up: https://quantum.ibm.com/
# After signup, save credentials in Python:
#   from qiskit_ibm_runtime import QiskitRuntimeService
#   QiskitRuntimeService.save_account(token="YOUR_TOKEN", instance="YOUR_CRN")

# Cipherstone Qbert (photonic chip)
# Contact: https://cipherstone.com/
CIPHERSTONE_API_KEY=your_cipherstone_key_here

# Anthropic API (for LLM inference experiments — optional)
ANTHROPIC_API_KEY=your_anthropic_key_here
